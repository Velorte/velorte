<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Product | VELÔRTE</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta http-equiv="Cache-Control" content="no-cache">
  <link rel="stylesheet" href="style.css?v=2">
  <style>
    .product-detail-container {
      max-width: 1000px;
      margin: 100px auto 50px;
      padding: 2rem;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 3rem;
    }
    .product-image-container img {
      width: 100%;
      border-radius: 12px;
    }
    .product-info h1 {
      font-size: 2rem;
      margin-bottom: 1rem;
      letter-spacing: 2px;
    }
    .product-info .price {
      font-size: 1.5rem;
      margin-bottom: 1.5rem;
    }
    .product-info p {
      color: #888;
      line-height: 1.6;
      margin-bottom: 2rem;
    }
    #size-options {
      display: flex;
      gap: 0.5rem;
      margin-bottom: 2rem;
      flex-wrap: wrap;
    }
    .size-btn {
      width: 45px;
      height: 45px;
      border: 1px solid rgba(255,255,255,0.3);
      background: transparent;
      color: #fff;
      cursor: pointer;
      border-radius: 6px;
    }
    .size-btn.selected, .size-btn:hover {
      background: #fff;
      color: #0a0a0a;
    }
    .add-to-cart {
      width: 100%;
      padding: 1rem;
      background: #fff;
      color: #0a0a0a;
      border: none;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 2px;
      cursor: pointer;
    }
    .back-link {
      display: inline-block;
      margin-top: 2rem;
      color: #666;
      text-decoration: none;
    }
    @media (max-width: 768px) {
      .product-detail-container {
        grid-template-columns: 1fr;
        margin-top: 80px;
      }
    }
  </style>
</head>
<body>

  <header>
    <nav>
      <h1>VELÔRTE</h1>
      <ul>
        <li><a href="index.html">Home</a></li>
        <li><a href="shop.html">Shop</a></li>
        <li><a href="about.html">About</a></li>
        <li><a href="contact.html">Contact</a></li>
        <li><a href="#" id="signin-btn" class="signin-link">Sign In</a></li>
      </ul>
    </nav>
  </header>

  <div id="signin-modal" class="modal">
    <div class="modal-content">
      <span class="close-btn" id="close-modal">&times;</span>
      <h2>Sign In</h2>
      <form id="login-form">
        <label>Email</label>
        <input type="email" id="email" required>
        <label>Password</label>
        <input type="password" id="password" required>
        <button type="submit" class="btn-submit">Sign In</button>
      </form>
    </div>
  </div>

  <div class="product-detail-container">
    <div class="product-image-container">
      <img id="product-image" src="" alt="Product">
    </div>
    <div class="product-info">
      <h1 id="product-name">Loading...</h1>
      <p class="price" id="product-price">$0</p>
      <p id="product-description">Loading...</p>
      <div id="size-options"></div>
      <button class="add-to-cart" onclick="alert('Added to cart!')">Add to Cart</button>
      <br>
      <a href="shop.html" class="back-link">← Back to Shop</a>
    </div>
  </div>

  <footer>
    <div class="footer-content">
      <h3>VELÔRTE</h3>
      <p>&copy; 2026 Velôrte</p>
    </div>
  </footer>

  <script src="script.js?v=2"></script>
</body>
</html>
